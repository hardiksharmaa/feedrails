generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  APP_STORE
  REDDIT
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id          String    @id @default(uuid())
  clerkUserId String    @unique
  email       String    @unique
  name        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sources     Source[]

  @@unique([userId, slug])
}

model Source {
  id          String        @id @default(uuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  type        SourceType
  config      Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  feedbacks   RawFeedback[]
}

model RawFeedback {
  id          String        @id @default(uuid())
  sourceId    String
  source      Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  content     String        @db.Text
  timestamp   DateTime      @default(now()) 
  metadata    Json?         
  fingerprint String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  insight     AnalyzedInsight? 
}

model AnalyzedInsight {
  id            String      @id @default(uuid())
  feedbackId    String      @unique
  feedback      RawFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  sentiment     Sentiment
  tags          String[]
  urgencyScore  Int
  summary       String      @db.Text
  createdAt     DateTime    @default(now())
}